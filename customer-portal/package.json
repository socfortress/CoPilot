{
	"name": "copilot-customer-portal",
	"type": "module",
	"version": "1.0.0",
	"private": true,
	"packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
	"engines": {
		"node": ">=18.0.0"
	},
	"scripts": {
		"dev": "vite --host 0.0.0.0 --port 3001",
		"dev:debug": "DEBUG=vite:* vite",
		"build": "run-p type-check \"build:only {@}\" --",
		"build:only": "vite build",
		"build:docker": "docker build .",
		"build:analyzer": "vite-bundle-visualizer -t sunburst",
		"build:check": "run-s libs:reload build lint type-check format build:docker",
		"preview": "vite build && echo '' && vite preview --port 4173 --host",
		"preview:only": "vite preview --port 4173 --host",
		"dup-check": "jscpd --ignore \"**/node_modules/**,**/dist/**,**/.nuxt/**,**/*.svg\" --min-tokens 100 --reporters console,html,json .",
		"type-check": "vue-tsc --build --force",
		"lint": "eslint . --fix",
		"format": "prettier --write src/",
		"lint-type-format": "run-s lint type-check format",
		"design-tokens": "node scripts/tokens-tool.js",
		"start-server": "cd ../backend && /opt/venv/bin/python copilot.py",
		"start-frontend": "vite --host 0.0.0.0 --port 3001",
		"start": "concurrently \"pnpm start-server\" \"pnpm start-frontend\"",
		"libs:check": "taze && depcheck",
		"libs:reload": "rm -rf node_modules pnpm-lock.yaml && pnpm install",
		"open:swagger": "open http://127.0.0.1:8000/docs"
	},
	"dependencies": {
		"@f3ve/vue-markdown-it": "^0.2.3",
		"@fontsource/jetbrains-mono": "^5.2.8",
		"@fontsource/lexend": "^5.2.11",
		"@fontsource/public-sans": "^5.2.7",
		"@shikijs/markdown-it": "^4.0.2",
		"@vueuse/core": "^14.2.1",
		"@vueuse/motion": "^3.0.3",
		"axios": "^1.13.6",
		"bytes": "^3.1.2",
		"colord": "^2.9.3",
		"dayjs": "^1.11.20",
		"detect-touch-device": "^1.1.6",
		"echarts": "^6.0.0",
		"file-saver": "^2.0.5",
		"html-entities": "^2.6.0",
		"jose": "^6.2.1",
		"js-md5": "^0.8.3",
		"lodash": "^4.17.23",
		"mitt": "^3.0.1",
		"naive-ui": "^2.44.1",
		"nanoid": "^5.1.7",
		"password-validator": "^5.3.0",
		"pinia": "^3.0.4",
		"pinia-plugin-persistedstate": "^4.7.1",
		"secure-ls": "^2.0.0",
		"shiki": "^4.0.2",
		"thememirror": "^2.0.1",
		"validator": "^13.15.26",
		"vue": "^3.5.30",
		"vue-advanced-cropper": "^2.8.9",
		"vue-highlight-words": "^3.0.1",
		"vue-i18n": "^11.3.0",
		"vue-router": "^5.0.3",
		"vue3-apexcharts": "^1.11.1",
		"vue3-marquee": "^4.2.2",
		"vuedraggable": "^4.1.0"
	},
	"optionalDependencies": {
		"@rollup/rollup-linux-x64-gnu": "^4.46.2",
		"treemate": "^0.3.11",
		"vueuc": "^0.4.64"
	},
	"devDependencies": {
		"@antfu/eslint-config": "~7.7.3",
		"@clack/prompts": "^1.1.0",
		"@iconify/vue": "^5.0.0",
		"@tailwindcss/vite": "^4.2.1",
		"@tsconfig/node20": "^20.1.9",
		"@types/bytes": "^3.1.5",
		"@types/file-saver": "^2.0.7",
		"@types/fs-extra": "^11.0.4",
		"@types/jsdom": "^28.0.0",
		"@types/lodash": "^4.17.24",
		"@types/markdown-it": "^14.1.2",
		"@types/node": "^25.5.0",
		"@types/validator": "^13.15.10",
		"@vitejs/plugin-vue": "^6.0.5",
		"@vitejs/plugin-vue-jsx": "^5.1.5",
		"@vue/tsconfig": "~0.9.0",
		"depcheck": "^1.4.7",
		"eslint": "~10.0.3",
		"flourite": "^1.3.0",
		"fs-extra": "^11.3.4",
		"jscpd": "^4.0.8",
		"jsdom": "^29.0.0",
		"npm-run-all2": "^8.0.4",
		"prettier": "^3.8.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"sass": "^1.98.0",
		"tailwindcss": "^4.2.1",
		"taze": "^19.10.0",
		"type-fest": "^5.4.4",
		"typescript": "~5.9.3",
		"vite": "^7.3.1",
		"vite-bundle-visualizer": "^1.2.1",
		"vite-plugin-inspect": "^11.3.3",
		"vite-plugin-vue-devtools": "^8.1.0",
		"vite-svg-loader": "^5.1.1",
		"vue-tsc": "^3.2.6"
	},
	"pnpm": {
		"peerDependencyRules": {
			"allowedVersions": {
				"eslint": "10"
			}
		},
		"onlyBuiltDependencies": [
			"@parcel/watcher",
			"@tailwindcss/oxide",
			"esbuild",
			"unrs-resolver"
		]
	}
}