{
	"name": "copilot-customer-portal",
	"type": "module",
	"version": "1.0.0",
	"private": true,
	"packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1",
	"engines": {
		"node": ">=18.0.0"
	},
	"scripts": {
		"dev": "vite --host 0.0.0.0 --port 3001",
		"dev:debug": "DEBUG=vite:* vite",
		"build": "run-p type-check \"build:only {@}\" --",
		"build:only": "vite build",
		"build:docker": "docker build .",
		"build:analyzer": "vite-bundle-visualizer -t sunburst",
		"build:check": "run-s libs:reload build lint type-check format build:docker",
		"preview": "vite build && echo '' && vite preview --port 4173 --host",
		"preview:only": "vite preview --port 4173 --host",
		"dup-check": "jscpd --ignore \"**/node_modules/**,**/dist/**,**/.nuxt/**,**/*.svg\" --min-tokens 100 --reporters console,html,json .",
		"type-check": "vue-tsc --build --force tsconfig.app.json",
		"lint": "eslint . --fix",
		"format": "prettier --write src/",
		"lint-type-format": "run-s lint type-check format",
		"design-tokens": "node scripts/tokens-tool.js",
		"start-server": "cd ../backend && /opt/venv/bin/python copilot.py",
		"start-frontend": "vite --host 0.0.0.0 --port 3001",
		"start": "concurrently \"pnpm start-server\" \"pnpm start-frontend\"",
		"libs:check": "taze && depcheck",
		"libs:reload": "rm -rf node_modules pnpm-lock.yaml && pnpm install",
		"open:swagger": "open http://127.0.0.1:8000/docs"
	},
	"dependencies": {
		"@f3ve/vue-markdown-it": "^0.2.3",
		"@fontsource/jetbrains-mono": "^5.3.0",
		"@fontsource/lexend": "^5.3.0",
		"@fontsource/public-sans": "^5.3.0",
		"@shikijs/markdown-it": "^4.3.1",
		"@vueuse/core": "^14.3.0",
		"@vueuse/motion": "^3.0.3",
		"axios": "^1.18.1",
		"bytes": "^3.1.2",
		"colord": "^2.9.3",
		"dayjs": "^1.11.21",
		"detect-touch-device": "^1.1.6",
		"echarts": "^6.1.0",
		"file-saver": "^2.0.5",
		"html-entities": "^2.6.0",
		"jose": "^6.2.4",
		"js-md5": "^0.9.2",
		"lodash": "^4.18.1",
		"mitt": "^3.0.1",
		"naive-ui": "^2.44.1",
		"nanoid": "^6.0.0",
		"password-validator": "^5.3.0",
		"pinia": "^4.0.2",
		"pinia-plugin-persistedstate": "^4.7.1",
		"rolldown": "1.2.0",
		"secure-ls": "^2.0.0",
		"shiki": "^4.3.1",
		"thememirror": "^2.0.1",
		"validator": "^13.15.35",
		"vue": "^3.5.40",
		"vue-advanced-cropper": "^2.8.9",
		"vue-echarts": "^8.0.1",
		"vue-highlight-words": "^3.0.1",
		"vue-i18n": "^11.4.7",
		"vue-router": "^5.2.0",
		"vue3-marquee": "^4.2.2",
		"vuedraggable": "^4.1.0"
	},
	"optionalDependencies": {
		"@rollup/rollup-linux-x64-gnu": "^4.46.2",
		"treemate": "^0.3.11",
		"vueuc": "^0.4.64"
	},
	"devDependencies": {
		"@antfu/eslint-config": "~9.2.0",
		"@clack/prompts": "^1.7.0",
		"@iconify/vue": "^5.0.1",
		"@tailwindcss/vite": "^4.3.3",
		"@tsconfig/node20": "^20.1.9",
		"@types/bytes": "^3.1.5",
		"@types/file-saver": "^2.0.7",
		"@types/fs-extra": "^11.0.4",
		"@types/jsdom": "^28.0.3",
		"@types/lodash": "^4.17.24",
		"@types/markdown-it": "^14.1.2",
		"@types/node": "^26.1.1",
		"@types/validator": "^13.15.10",
		"@vitejs/plugin-vue": "^6.0.8",
		"@vitejs/plugin-vue-jsx": "^5.1.6",
		"@vue/tsconfig": "~0.9.1",
		"depcheck": "^1.4.7",
		"eslint": "~10.8.0",
		"flourite": "^1.3.0",
		"fs-extra": "^11.4.0",
		"jscpd": "^5.0.12",
		"jsdom": "^29.1.1",
		"npm-run-all2": "^9.0.2",
		"prettier": "^3.9.6",
		"prettier-plugin-tailwindcss": "^0.8.1",
		"sass": "^1.101.7",
		"tailwindcss": "^4.3.3",
		"taze": "^19.16.0",
		"type-fest": "^5.8.0",
		"typescript": "~6.0.3",
		"vite": "^8.1.5",
		"vite-bundle-visualizer": "^1.2.1",
		"vite-plugin-inspect": "^12.0.2",
		"vite-plugin-vue-devtools": "^8.1.5",
		"vite-svg-loader": "^5.1.1",
		"vue-tsc": "^3.3.8"
	}
}