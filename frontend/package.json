		"html-entities": "^2.6.0",
		"jose": "^6.2.3",
		"js-md5": "^0.8.3",
		"lodash": "^4.18.1",
		"mitt": "^3.0.1",
		"naive-ui": "^2.44.1",
		"nanoid": "^5.1.15",
		"papaparse": "^5.5.4",
		"password-generator": "^3.0.0",
		"password-validator": "^5.3.0",
		"pinia": "^3.0.4",
		"pinia-plugin-persistedstate": "^4.7.1",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-router-dom": "^7.18.0",
		"react18-json-view": "^0.2.10",
		"remark-breaks": "^4.0.0",
		"rolldown": "1.0.1",
		"secure-ls": "^2.0.0",
		"shiki": "^4.2.0",
		"thememirror": "^2.0.1",
		"validator": "^13.15.35",
