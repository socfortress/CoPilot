{
	"name": "copilot",
	"type": "module",
	"version": "1.0.0",
	"private": true,
	"packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
	"engines": {
		"node": ">=24.0.0"
	},
	"scripts": {
		"dev": "vite --host 0.0.0.0",
		"dev:debug": "DEBUG=vite:* vite",
		"build": "run-p type-check \"build:only {@}\" --",
		"build:only": "vite build",
		"build:docker": "docker build .",
		"build:analyzer": "vite-bundle-visualizer -t sunburst",
		"build:check": "run-s libs:reload build lint type-check format test:unit build:docker",
		"preview": "vite build && echo '' && vite preview --port 4173 --host",
		"preview:only": "vite preview --port 4173 --host",
		"test:unit": "vitest run",
		"dup-check": "jscpd --ignore \"**/node_modules/**,**/dist/**,**/.nuxt/**,**/*.svg\" --min-tokens 100 --reporters console,html,json .",
		"type-check": "vue-tsc --build --force tsconfig.app.json",
		"lint": "eslint . --fix",
		"format": "prettier --write src/",
		"lint-type-format": "run-s lint type-check format",
		"design-tokens": "node scripts/tokens-tool.js",
		"start-server:old": "cd ../backend && uvicorn copilot:app --reload --port=5000",
		"start-server:venv": "cd ../backend && source .venv/bin/activate && uvicorn copilot:app --port=5000 --log-level debug",
		"start-server": "cd ../backend && /opt/venv/bin/python copilot.py",
		"start-frontend": "vite --host 0.0.0.0",
		"start": "concurrently \"pnpm start-server\" \"pnpm start-frontend\"",
		"libs:check": "taze && depcheck",
		"libs:reload": "rm -rf node_modules pnpm-lock.yaml && pnpm install",
		"open:swagger": "open http://127.0.0.1:5000/docs#/",
		"open:redoc": "open http://127.0.0.1:5000/redoc"
	},
	"dependencies": {
		"@ajoelp/json-to-formdata": "^1.5.0",
		"@codemirror/commands": "^6.10.4",
		"@codemirror/lang-javascript": "^6.2.5",
		"@codemirror/lang-xml": "^6.1.0",
		"@codemirror/lint": "^6.9.7",
		"@codemirror/state": "^6.7.0",
