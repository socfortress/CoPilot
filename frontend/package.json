		"@fontsource/lexend": "^5.2.11",
		"@fontsource/public-sans": "^5.2.7",
		"@microsoft/fetch-event-source": "^2.0.1",
		"@mui/material": "^9.1.2",
		"@shikijs/markdown-it": "^4.2.0",
		"@shuffleio/shuffle-mcps": "^0.0.33",
		"@simplewebauthn/browser": "^13.3.0",
		"@types/codemirror": "^5.60.17",
		"@vueuse/core": "^14.3.0",
		"@vueuse/motion": "^3.0.3",
		"algoliasearch": "^5.55.1",
		"axios": "^1.18.1",
