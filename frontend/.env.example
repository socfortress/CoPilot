# base url
VITE_API_URL=https://0.0.0.0:5000

# value in seconds
VITE_TOKEN_DEBOUNCE_TIME=10

# alert if value is over
VITE_UNCOMMITTED_JOURNAL_ENTRIES_THRESHOLD=50000

# value in seconds
VITE_HEALTHCHECKS_INTERVAL=120

# Base URL `@shuffleio/shuffle-mcps` uses for every API/MCP fetch from
# the embeds (search, auth, chat, actions). Defaults to the CoPilot
# same-origin proxy at `/api/shuffle/integrations/proxy`; only override
# if you're routing the embeds at a different gateway.
VITE_SHUFFLE_API_URL=/api/shuffle/integrations/proxy
