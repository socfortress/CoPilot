# base url
VITE_API_URL=https://0.0.0.0:5000

# value in seconds
VITE_TOKEN_DEBOUNCE_TIME=10

# alert if value is over
VITE_UNCOMMITTED_JOURNAL_ENTRIES_THRESHOLD=50000

# value in seconds
VITE_HEALTHCHECKS_INTERVAL=120

# shuffle api base url
VITE_SHUFFLE_API_BASE_URL=/api/shuffle/integrations/proxy
