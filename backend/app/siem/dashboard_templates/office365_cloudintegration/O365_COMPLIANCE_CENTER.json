{
  "id": "O365_COMPLIANCE_CENTER",
  "title": "Office 365 - Compliance Center",
  "description": "Microsoft Compliance Center activity: compliance operations, content-level events, policy actions, and audit log searches across the compliance workload.",
  "panels": [
    {
      "id": "alerts",
      "title": "Alerts (rule level ≥ 12)",
      "type": "stat",
      "w": 4,
      "h": 100,
      "lucene": "data_office365_Workload:Compliance AND rule_level:>=12"
    },
    {
      "id": "total_events",
      "title": "Total Events",
      "type": "stat",
      "w": 4,
      "h": 100,
      "lucene": "data_office365_Workload:Compliance"
    },
    {
      "id": "max_severity",
      "title": "Max Severity",
      "type": "stat",
      "w": 4,
      "h": 100,
      "lucene": "data_office365_Workload:Compliance"
    },
    {
      "id": "operations_over_time",
      "title": "Operations Over Time",
      "type": "histogram",
      "w": 12,
      "h": 200,
      "lucene": "data_office365_Workload:Compliance"
    },
    {
      "id": "by_operation",
      "title": "Events by Operation (Top 10)",
      "type": "pie",
      "w": 6,
      "h": 300,
      "lucene": "data_office365_Workload:Compliance",
      "field": "data_office365_Operation",
      "size": 10
    },
    {
      "id": "by_content",
      "title": "Events by Content",
      "type": "pie",
      "w": 6,
      "h": 300,
      "lucene": "data_office365_Workload:Compliance",
      "field": "data_office365_ItemName",
      "size": 10
    },
    {
      "id": "top_operations",
      "title": "Top Operations",
      "type": "bar_h",
      "w": 6,
      "h": 320,
      "lucene": "data_office365_Workload:Compliance",
      "field": "data_office365_Operation",
      "size": 15
    },
    {
      "id": "top_content",
      "title": "Top Content Items",
      "type": "bar_h",
      "w": 6,
      "h": 320,
      "lucene": "data_office365_Workload:Compliance",
      "field": "data_office365_ItemName",
      "size": 15
    },
    {
      "id": "top_rules",
      "title": "Top Rules Triggered",
      "type": "bar_h",
      "w": 6,
      "h": 320,
      "lucene": "data_office365_Workload:Compliance AND rule_level:>=12",
      "field": "rule_description",
      "size": 10
    }
  ]
}
