{
  "id": "O365_ONEDRIVE",
  "title": "Office 365 - OneDrive",
  "description": "OneDrive for Business activity: file operations, sharing events, link-containing messages, session tracking, user activity, and source country analysis.",
  "panels": [
    {
      "id": "alerts",
      "title": "Alerts (rule level ≥ 12)",
      "type": "stat",
      "w": 3,
      "h": 100,
      "lucene": "data_office365_Workload:OneDrive AND rule_level:>=12"
    },
    {
      "id": "total_events",
      "title": "Total Events",
      "type": "stat",
      "w": 3,
      "h": 100,
      "lucene": "data_office365_Workload:OneDrive"
    },
    {
      "id": "messages_with_links",
      "title": "Messages Containing Links",
      "type": "stat",
      "w": 3,
      "h": 100,
      "lucene": "data_office365_Workload:OneDrive AND data_office365_Operation:MessageCreatedHasLink"
    },
    {
      "id": "sessions_started",
      "title": "Sessions Started",
      "type": "stat",
      "w": 3,
      "h": 100,
      "lucene": "data_office365_Workload:OneDrive AND data_office365_Operation:TeamsSessionStarted"
    },
    {
      "id": "operations_over_time",
      "title": "Operations Over Time",
      "type": "histogram",
      "w": 12,
      "h": 200,
      "lucene": "data_office365_Workload:OneDrive"
    },
    {
      "id": "by_operation",
      "title": "Events by Operation (Top 10)",
      "type": "pie",
      "w": 6,
      "h": 300,
      "lucene": "data_office365_Workload:OneDrive",
      "field": "data_office365_Operation",
      "size": 10
    },
    {
      "id": "by_user",
      "title": "Events by User",
      "type": "pie",
      "w": 6,
      "h": 300,
      "lucene": "data_office365_Workload:OneDrive",
      "field": "data_office365_UserId",
      "size": 10
    },
    {
      "id": "top_operations",
      "title": "Top Operations",
      "type": "bar_h",
      "w": 6,
      "h": 320,
      "lucene": "data_office365_Workload:OneDrive",
      "field": "data_office365_Operation",
      "size": 15
    },
    {
      "id": "top_users",
      "title": "Top Users",
      "type": "bar_h",
      "w": 6,
      "h": 320,
      "lucene": "data_office365_Workload:OneDrive",
      "field": "data_office365_UserId",
      "size": 15
    },
    {
      "id": "by_country",
      "title": "Events by Source Country",
      "type": "bar_h",
      "w": 6,
      "h": 320,
      "lucene": "data_office365_Workload:OneDrive",
      "field": "data_office365_ClientIP_country_code",
      "size": 15
    },
    {
      "id": "top_rules",
      "title": "Top Rules Triggered",
      "type": "bar_h",
      "w": 6,
      "h": 320,
      "lucene": "data_office365_Workload:OneDrive AND rule_level:>=12",
      "field": "rule_description",
      "size": 10
    }
  ]
}
