{
  "id": "O365_POWERBI",
  "title": "Office 365 - Power BI",
  "description": "Power BI activity monitoring: report access, dashboard views, dataset operations, user activity, source country analysis, and alert tracking.",
  "panels": [
    {
      "id": "alerts",
      "title": "Alerts (rule level ≥ 12)",
      "type": "stat",
      "w": 3,
      "h": 100,
      "lucene": "data_office365_Workload:PowerBI AND rule_level:>=12"
    },
    {
      "id": "total_events",
      "title": "Total Events",
      "type": "stat",
      "w": 3,
      "h": 100,
      "lucene": "data_office365_Workload:PowerBI"
    },
    {
      "id": "max_severity",
      "title": "Max Rule Severity",
      "type": "stat",
      "w": 3,
      "h": 100,
      "lucene": "data_office365_Workload:PowerBI"
    },
    {
      "id": "unique_users",
      "title": "Unique Users",
      "type": "stat",
      "w": 3,
      "h": 100,
      "lucene": "data_office365_Workload:PowerBI"
    },
    {
      "id": "activity_over_time",
      "title": "Activity Over Time",
      "type": "histogram",
      "w": 12,
      "h": 200,
      "lucene": "data_office365_Workload:PowerBI"
    },
    {
      "id": "by_activity",
      "title": "Events by Activity (Top 10)",
      "type": "pie",
      "w": 6,
      "h": 300,
      "lucene": "data_office365_Workload:PowerBI",
      "field": "data_office365_Activity",
      "size": 10
    },
    {
      "id": "by_user",
      "title": "Events by User",
      "type": "pie",
      "w": 6,
      "h": 300,
      "lucene": "data_office365_Workload:PowerBI",
      "field": "data_office365_UserId",
      "size": 10
    },
    {
      "id": "top_activities",
      "title": "Top Activities",
      "type": "bar_h",
      "w": 6,
      "h": 320,
      "lucene": "data_office365_Workload:PowerBI",
      "field": "data_office365_Activity",
      "size": 15
    },
    {
      "id": "top_artifacts",
      "title": "Top Artifact Names",
      "type": "bar_h",
      "w": 6,
      "h": 320,
      "lucene": "data_office365_Workload:PowerBI",
      "field": "data_office365_ArtifactName",
      "size": 15
    },
    {
      "id": "top_users",
      "title": "Top Users",
      "type": "bar_h",
      "w": 6,
      "h": 320,
      "lucene": "data_office365_Workload:PowerBI",
      "field": "data_office365_UserId",
      "size": 15
    },
    {
      "id": "by_country",
      "title": "Events by Source Country",
      "type": "bar_h",
      "w": 6,
      "h": 320,
      "lucene": "data_office365_Workload:PowerBI",
      "field": "data_office365_ClientIP_country_code",
      "size": 15
    }
  ]
}
