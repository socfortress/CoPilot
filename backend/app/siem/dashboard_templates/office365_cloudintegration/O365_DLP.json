{
  "id": "O365_DLP",
  "title": "Office 365 - Data Loss Prevention",
  "description": "Data Loss Prevention (DLP) policy events: rule matches, policy violations, DLP operations, and affected content across the DLP workload.",
  "panels": [
    {
      "id": "alerts",
      "title": "Alerts (rule level ≥ 12)",
      "type": "stat",
      "w": 4,
      "h": 100,
      "lucene": "data_office365_Workload:DLP AND rule_level:>=12"
    },
    {
      "id": "total_events",
      "title": "Total Events",
      "type": "stat",
      "w": 4,
      "h": 100,
      "lucene": "data_office365_Workload:DLP"
    },
    {
      "id": "max_severity",
      "title": "Max Severity",
      "type": "stat",
      "w": 4,
      "h": 100,
      "lucene": "data_office365_Workload:DLP"
    },
    {
      "id": "operations_over_time",
      "title": "Operations Over Time",
      "type": "histogram",
      "w": 12,
      "h": 200,
      "lucene": "data_office365_Workload:DLP"
    },
    {
      "id": "by_operation",
      "title": "Events by Operation (Top 10)",
      "type": "pie",
      "w": 6,
      "h": 300,
      "lucene": "data_office365_Workload:DLP",
      "field": "data_office365_Operation",
      "size": 10
    },
    {
      "id": "by_rule",
      "title": "Events by DLP Rule",
      "type": "pie",
      "w": 6,
      "h": 300,
      "lucene": "data_office365_Workload:DLP",
      "field": "data_office365_RuleName",
      "size": 10
    },
    {
      "id": "top_operations",
      "title": "Top Operations",
      "type": "bar_h",
      "w": 6,
      "h": 320,
      "lucene": "data_office365_Workload:DLP",
      "field": "data_office365_Operation",
      "size": 15
    },
    {
      "id": "top_rules_dlp",
      "title": "Top DLP Rules",
      "type": "bar_h",
      "w": 6,
      "h": 320,
      "lucene": "data_office365_Workload:DLP",
      "field": "data_office365_RuleName",
      "size": 15
    },
    {
      "id": "top_rules",
      "title": "Top Detection Rules Triggered",
      "type": "bar_h",
      "w": 6,
      "h": 320,
      "lucene": "data_office365_Workload:DLP AND rule_level:>=12",
      "field": "rule_description",
      "size": 10
    }
  ]
}
