{
  "id": "O365_ENDPOINT",
  "title": "Office 365 - Endpoint (Defender)",
  "description": "Microsoft Defender for Endpoint activity: endpoint alerts, detection titles, operations, and security events from the MicrosoftDefender workload.",
  "panels": [
    {
      "id": "alerts",
      "title": "Alerts (rule level ≥ 12)",
      "type": "stat",
      "w": 4,
      "h": 100,
      "lucene": "data_office365_Workload:MicrosoftDefender AND rule_level:>=12"
    },
    {
      "id": "total_events",
      "title": "Total Events",
      "type": "stat",
      "w": 4,
      "h": 100,
      "lucene": "data_office365_Workload:MicrosoftDefender"
    },
    {
      "id": "max_severity",
      "title": "Max Severity",
      "type": "stat",
      "w": 4,
      "h": 100,
      "lucene": "data_office365_Workload:MicrosoftDefender"
    },
    {
      "id": "operations_over_time",
      "title": "Operations Over Time",
      "type": "histogram",
      "w": 12,
      "h": 200,
      "lucene": "data_office365_Workload:MicrosoftDefender"
    },
    {
      "id": "by_operation",
      "title": "Events by Operation (Top 10)",
      "type": "pie",
      "w": 6,
      "h": 300,
      "lucene": "data_office365_Workload:MicrosoftDefender",
      "field": "data_office365_Operation",
      "size": 10
    },
    {
      "id": "by_title",
      "title": "Events by Alert Title",
      "type": "pie",
      "w": 6,
      "h": 300,
      "lucene": "data_office365_Workload:MicrosoftDefender",
      "field": "data_office365_Title",
      "size": 10
    },
    {
      "id": "top_operations",
      "title": "Top Operations",
      "type": "bar_h",
      "w": 6,
      "h": 320,
      "lucene": "data_office365_Workload:MicrosoftDefender",
      "field": "data_office365_Operation",
      "size": 15
    },
    {
      "id": "top_titles",
      "title": "Top Alert Titles",
      "type": "bar_h",
      "w": 6,
      "h": 320,
      "lucene": "data_office365_Workload:MicrosoftDefender",
      "field": "data_office365_Title",
      "size": 15
    },
    {
      "id": "top_rules",
      "title": "Top Rules Triggered",
      "type": "bar_h",
      "w": 6,
      "h": 320,
      "lucene": "data_office365_Workload:MicrosoftDefender AND rule_level:>=12",
      "field": "rule_description",
      "size": 10
    }
  ]
}
