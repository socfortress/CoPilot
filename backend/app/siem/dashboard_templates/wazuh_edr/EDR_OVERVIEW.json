{
  "id": "EDR_OVERVIEW",
  "title": "Wazuh EDR - Overview",
  "description": "High-level overview of all EDR endpoint activity: total events, severity distribution, most active agents, Sysmon event type breakdown, and top triggered detection rules.",
  "panels": [
    {
      "id": "total_events",
      "title": "Total Events",
      "type": "stat",
      "w": 3,
      "h": 100,
      "lucene": "*"
    },
    {
      "id": "high_severity",
      "title": "High Severity (≥ 12)",
      "type": "stat",
      "w": 3,
      "h": 100,
      "lucene": "rule_level:>11"
    },
    {
      "id": "critical",
      "title": "Critical (≥ 15)",
      "type": "stat",
      "w": 3,
      "h": 100,
      "lucene": "rule_level:>14"
    },
    {
      "id": "process_events",
      "title": "Process Create Events",
      "type": "stat",
      "w": 3,
      "h": 100,
      "lucene": "data_win_system_eventID:1"
    },
    {
      "id": "events_over_time",
      "title": "Events Over Time",
      "type": "histogram",
      "w": 12,
      "h": 200,
      "lucene": "*"
    },
    {
      "id": "by_rule_level",
      "title": "By Rule Severity Level",
      "type": "pie",
      "w": 4,
      "h": 300,
      "lucene": "*",
      "field": "rule_level",
      "size": 10
    },
    {
      "id": "by_sysmon_type",
      "title": "By Sysmon Event Type",
      "type": "pie",
      "w": 4,
      "h": 300,
      "lucene": "data_win_system_eventID:*",
      "field": "data_win_system_eventID",
      "size": 15
    },
    {
      "id": "by_agent",
      "title": "By Agent",
      "type": "pie",
      "w": 4,
      "h": 300,
      "lucene": "*",
      "field": "agent_name",
      "size": 10
    },
    {
      "id": "top_rules",
      "title": "Top Rules Triggered",
      "type": "bar_h",
      "w": 6,
      "h": 320,
      "lucene": "*",
      "field": "rule_description",
      "size": 10
    },
    {
      "id": "top_agents",
      "title": "Most Active Agents",
      "type": "bar_h",
      "w": 6,
      "h": 320,
      "lucene": "*",
      "field": "agent_name",
      "size": 10
    }
  ]
}
